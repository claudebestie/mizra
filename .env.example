# ============================================================
# MIZRA BLOG AUTOMATION — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# Ne JAMAIS committer .env dans Git !
# ============================================================

# Anthropic (claude.ai/settings/api-keys)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (supabase.com → Settings → API)
SUPABASE_URL=https://XXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # Service Role key (pas l'anon key !)

# GitHub Personal Access Token
# → github.com/settings/tokens → New token (classic)
# → Permissions: repo (full), workflow
GH_PAT_TOKEN=ghp_...
GITHUB_OWNER=margauxadda      # Ton username GitHub
GITHUB_REPO=getmizra          # Nom du repo

# Netlify Build Hook
# → app.netlify.com → ton site → Site Settings → Build & Deploy → Build hooks
# → Crée un hook "Blog Automation" et copie l'URL
NETLIFY_BUILD_HOOK=https://api.netlify.com/build_hooks/XXXXXX

# PayPlus Payment Gateway (restapi.payplus.co.il)
# → Dashboard PayPlus → Settings → API
PAYPLUS_API_KEY=your_api_key
PAYPLUS_SECRET_KEY=your_secret_key
PAYPLUS_PAYMENT_PAGE_UID=your_payment_page_uid
PAYPLUS_WEBHOOK_SECRET=your_webhook_secret

# Optionnel
ARTICLES_PER_RUN=5
