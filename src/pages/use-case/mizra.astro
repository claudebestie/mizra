---
import SEOPage from '../../layouts/SEOPage.astro';

const site = 'https://getmizra.com';
const canonical = `${site}/use-case/mizra/`;

const articleLD = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Case Study: Mizra — How a Tel Aviv Web Agency Tripled Its Lead Volume with a Custom Back-Office",
  "description": "How Mizra industrialized its prospection, centralized 9,595 leads and automated quotes — without any SaaS dependency. Built with Supabase, Vercel, WATI.",
  "datePublished": "2026-03-23",
  "author": { "@type": "Organization", "name": "Mizra", "url": site },
  "publisher": { "@type": "Organization", "name": "Mizra", "url": site },
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonical },
};

const breadcrumbLD = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${site}/` },
    { "@type": "ListItem", "position": 2, "name": "Use Cases", "item": `${site}/use-case/mizra/` },
    { "@type": "ListItem", "position": 3, "name": "Mizra" },
  ],
};
---

<SEOPage
  title="Case Study: Mizra — 3× Lead Volume with a Custom Back-Office"
  description="How Mizra tripled its lead volume with a custom back-office: 9,595 leads imported, CRM, automated quotes, payments, and KPI dashboard — no SaaS fees."
  canonical={canonical}
  jsonLd={[articleLD, breadcrumbLD]}
>

<div class="cx">
  <nav class="breadcrumbs" aria-label="Breadcrumb" style="direction:ltr;text-align:left;">
    <a href="/">Home</a><span>/</span><a href="/use-case/mizra/">Use Cases</a><span>/</span><span>Mizra</span>
  </nav>
</div>

<article class="uc" style="direction:ltr;text-align:left;">
<div class="cx">

  <!-- HERO -->
  <header class="uc-hero">
    <span class="uc-tag">Case Study · Web Agency · Israel</span>
    <h1>Mizra <i>tripled its lead volume</i> with a custom back-office</h1>
    <p class="uc-sub">How an Israeli web agency industrialized its prospection, centralized its leads and automated its quotes — without depending on any SaaS.</p>
  </header>

  <!-- METRICS -->
  <div class="uc-metrics uc-metrics-4 rv">
    <div class="uc-metric">
      <div class="uc-metric-val">9,595</div>
      <div class="uc-metric-lbl">Leads imported</div>
    </div>
    <div class="uc-metric">
      <div class="uc-metric-val">48h</div>
      <div class="uc-metric-lbl">Site + BO delivery</div>
    </div>
    <div class="uc-metric">
      <div class="uc-metric-val">€0/mo</div>
      <div class="uc-metric-lbl">No recurring SaaS</div>
    </div>
    <div class="uc-metric">
      <div class="uc-metric-val">3×</div>
      <div class="uc-metric-lbl">Leads processed / week</div>
    </div>
  </div>

  <!-- CONTENT GRID -->
  <div class="uc-grid">
    <div class="uc-main">

      <!-- CONTEXTE -->
      <section class="uc-section rv">
        <div class="sl">Context</div>
        <h2>Mizra: delivering professional websites in 48h from Tel Aviv</h2>
        <p>Mizra is an Israeli web agency founded by Margaux, delivering professional websites for local small businesses (restaurants, lawyers, barbers, coaches…) in 48 hours, starting at 1,500 NIS.</p>
        <p>The challenge: a dense market, short sales cycles, and a prospect volume that quickly exceeds the capacity of manual follow-up.</p>

        <div class="uc-context-grid rv">
          <div class="uc-context-cell">
            <div class="uc-context-label">Target Market</div>
            <div class="uc-context-val">Tel Aviv SMBs, restaurants, freelancers</div>
          </div>
          <div class="uc-context-cell">
            <div class="uc-context-label">Main Channel</div>
            <div class="uc-context-val">WhatsApp Business + email outreach</div>
          </div>
          <div class="uc-context-cell">
            <div class="uc-context-label">Lead Volume</div>
            <div class="uc-context-val">9,595 contacts imported via scraping</div>
          </div>
          <div class="uc-context-cell">
            <div class="uc-context-label">Challenge</div>
            <div class="uc-context-val">Scale operations without management tools</div>
          </div>
        </div>
      </section>

      <!-- BO -->
      <section class="uc-section rv">
        <div class="sl">Solution</div>
        <h2>A back-office that centralizes everything</h2>
        <p>Mizra built a complete custom back-office — hosted on Vercel, powered by Supabase — replacing Excel, Notion, and paid CRM tools in one go.</p>

        <div class="uc-bo">
          <h3>Mizra back-office — active modules</h3>
          <p style="color:var(--txl);font-size:.88rem;margin-bottom:20px;">Single admin interface, accessible anywhere, no monthly subscription.</p>
          <div class="uc-bo-grid">
            <div class="uc-bo-item">
              <span class="uc-bo-icon">📥</span>
              <div>
                <strong>Massive CSV Import</strong>
                <p>9,595 leads injected in one command from Lobstr</p>
              </div>
            </div>
            <div class="uc-bo-item">
              <span class="uc-bo-icon">🔄</span>
              <div>
                <strong>Tracking Pipeline</strong>
                <p>Visual statuses: New → Contacted → Quote → Signed</p>
              </div>
            </div>
            <div class="uc-bo-item">
              <span class="uc-bo-icon">📄</span>
              <div>
                <strong>Auto-Generated Quotes</strong>
                <p>Numbered PDFs, sent by email in 1 click</p>
              </div>
            </div>
            <div class="uc-bo-item">
              <span class="uc-bo-icon">💳</span>
              <div>
                <strong>Integrated Payments</strong>
                <p>PayPlus gateway connected, payment tracking</p>
              </div>
            </div>
            <div class="uc-bo-item">
              <span class="uc-bo-icon">📊</span>
              <div>
                <strong>Real-Time KPIs</strong>
                <p>Revenue, conversion rate, leads by source, weekly performance</p>
              </div>
            </div>
            <div class="uc-bo-item">
              <span class="uc-bo-icon">📱</span>
              <div>
                <strong>WhatsApp WATI</strong>
                <p>Connected outreach templates, response tracking</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- PIPELINE -->
      <section class="uc-section rv">
        <div class="sl">Sales Flow</div>
        <h2>A pipeline from A to Z</h2>
        <p>Every lead follows a tracked journey, from scraping to signature, with zero information loss.</p>

        <div class="uc-pipeline">
          <div class="uc-pipe-step"><span class="uc-pipe-num">9.6k</span>Scraping</div>
          <div class="uc-pipe-step"><span class="uc-pipe-num">→ BO</span>Import</div>
          <div class="uc-pipe-step"><span class="uc-pipe-num">WA</span>Outreach</div>
          <div class="uc-pipe-step"><span class="uc-pipe-num">PDF</span>Quote</div>
          <div class="uc-pipe-step"><span class="uc-pipe-num">✓</span>Signed</div>
        </div>
      </section>

      <!-- QUOTE -->
      <blockquote class="uc-quote rv">
        <p>"Before the back-office, I was juggling between WhatsApp, Excel and email. Now everything is in one interface — leads come in, quotes go out, and I see my pipeline in real time."</p>
        <cite>— Margaux, founder of Mizra · getmizra.com</cite>
      </blockquote>

      <!-- RESULTS -->
      <section class="uc-section rv">
        <div class="sl">Results</div>
        <h2>Proof by numbers</h2>
        <div class="uc-results">
          <div class="uc-result">
            <div class="uc-result-num">9,595</div>
            <p>Leads imported, qualified and tracked from the BO</p>
          </div>
          <div class="uc-result">
            <div class="uc-result-num">3×</div>
            <p>More prospects processed each week vs. manual management</p>
          </div>
          <div class="uc-result">
            <div class="uc-result-num">48h</div>
            <p>From order to live site — deadline met on every project</p>
          </div>
          <div class="uc-result">
            <div class="uc-result-num">0 SaaS</div>
            <p>No CRM or invoicing subscription — everything is proprietary</p>
          </div>
        </div>
      </section>

      <p class="uc-footer-note">
        Mizra is an Israeli web agency and Lancio partner. Discover their approach on <a href="https://getmizra.com">getmizra.com</a>
      </p>

    </div>

    <!-- SIDEBAR -->
    <aside class="uc-sidebar">
      <div class="uc-card">
        <h4>Client Profile</h4>
        <div class="uc-row"><span>Client</span><span>Mizra</span></div>
        <div class="uc-row"><span>Sector</span><span>Web Agency</span></div>
        <div class="uc-row"><span>Country</span><span>Israel 🇮🇱</span></div>
        <div class="uc-row"><span>Delivery</span><span>48 hours</span></div>
        <div class="uc-row"><span>Scope</span><span>Site + Back-office</span></div>
      </div>

      <div class="uc-card">
        <h4>Tech Stack</h4>
        <div class="uc-tags">
          <span class="uc-tag-item">Supabase</span>
          <span class="uc-tag-item">Vercel</span>
          <span class="uc-tag-item">Astro</span>
          <span class="uc-tag-item">WATI</span>
          <span class="uc-tag-item">Brevo</span>
          <span class="uc-tag-item">PayPlus</span>
          <span class="uc-tag-item">Resend</span>
        </div>
      </div>

      <div class="uc-card">
        <h4>Modules Delivered</h4>
        <div class="uc-row"><span>Website</span><span>✓</span></div>
        <div class="uc-row"><span>CRM + Leads</span><span>✓</span></div>
        <div class="uc-row"><span>PDF Quotes</span><span>✓</span></div>
        <div class="uc-row"><span>Invoicing</span><span>✓</span></div>
        <div class="uc-row"><span>Payments</span><span>✓</span></div>
        <div class="uc-row"><span>Dashboard</span><span>✓</span></div>
      </div>

      <div class="uc-backlink">
        <div class="uc-backlink-label">Lancio Partner</div>
        <p>Lancio.fr delivers professional websites for French freelancers and small businesses starting at €650.</p>
        <a href="https://lancio.fr" target="_blank" rel="noopener" class="btn btn-p btn-sm">Visit Lancio.fr →</a>
      </div>
    </aside>
  </div>

</div>
</article>

</SEOPage>
