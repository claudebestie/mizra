---
import { getCollection } from 'astro:content';
import SEOPage from '../../layouts/SEOPage.astro';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const enPosts = allPosts.filter(p => p.data.lang === 'en');
const hePosts = allPosts.filter(p => p.data.lang === 'he');

const site = 'https://getmizra.com';
const canonical = `${site}/blog/`;
const title = 'Blog | Mizra';
const description = 'Tips, guides and news for building a professional website. The Mizra blog.';

const breadcrumbLD = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${site}/` },
    { "@type": "ListItem", "position": 2, "name": "Blog" },
  ],
};
---

<SEOPage title={title} description={description} canonical={canonical} jsonLd={[breadcrumbLD]}>

<div class="cx">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <div class="en"><a href="/">Home</a><span>/</span><span>Blog</span></div>
    <div class="he"><a href="/">דף הבית</a><span>/</span><span>בלוג</span></div>
  </nav>
</div>

<section class="page-hero">
  <div class="cx">
    <p class="sl">Blog</p>
    <div class="en">
      <h1 style="font-family:var(--sf);font-size:clamp(2rem,4.5vw,3.2rem);color:var(--navy);margin:16px 0;line-height:1.15">
        Articles & <i style="color:var(--or)">guides</i>
      </h1>
      <p style="color:var(--tx);font-size:1.05rem;max-width:640px;margin:0 auto;line-height:1.7">
        Practical tips to create, optimize and grow your professional website.
      </p>
    </div>
    <div class="he">
      <h1 style="font-family:var(--sf);font-size:clamp(2rem,4.5vw,3.2rem);color:var(--navy);margin:16px 0;line-height:1.15">
        <i style="color:var(--or)">מאמרים</i> ומדריכים
      </h1>
      <p style="color:var(--tx);font-size:1.05rem;max-width:640px;margin:0 auto;line-height:1.7">
        טיפים מעשיים ליצירה, אופטימיזציה וצמיחה של האתר המקצועי שלכם.
      </p>
    </div>
  </div>
</section>

<section class="sec">
  <div class="cx">
    <!-- English articles -->
    <div class="en">
      {enPosts.length === 0 ? (
        <p style="text-align:center;color:var(--txl);padding:48px 0">No articles yet. Come back soon!</p>
      ) : (
        <div class="blog-list-grid">
          {enPosts.map((post) => (
            <a href={`/blog/${post.id}/`} class="blog-list-card rv">
              <div class="blog-list-body">
                <div class="blog-list-meta">
                  <time datetime={post.data.date}>
                    {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                  {post.data.readingTime && <span>{post.data.readingTime}</span>}
                </div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="blog-list-link">Read article &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Hebrew articles -->
    <div class="he">
      {hePosts.length === 0 ? (
        <p style="text-align:center;color:var(--txl);padding:48px 0">אין מאמרים עדיין. חזרו בקרוב!</p>
      ) : (
        <div class="blog-list-grid">
          {hePosts.map((post) => (
            <a href={`/blog/${post.id}/`} class="blog-list-card rv">
              <div class="blog-list-body">
                <div class="blog-list-meta">
                  <time datetime={post.data.date}>
                    {new Date(post.data.date).toLocaleDateString('he-IL', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                  {post.data.readingTime && <span>{post.data.readingTime}</span>}
                </div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="blog-list-link">&larr; קראו את המאמר</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .blog-list-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 20px;
  }

  .blog-list-card {
    display: block;
    background: var(--white);
    border: 1px solid var(--bd);
    border-radius: 12px;
    text-decoration: none;
    transition: transform .3s, box-shadow .3s;
    overflow: hidden;
  }

  .blog-list-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,.06);
  }

  .blog-list-body {
    padding: 24px;
  }

  .blog-list-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: .82rem;
    color: var(--txl);
    margin-bottom: 12px;
  }

  .blog-list-card h2 {
    font-family: var(--sf);
    font-size: 1.15rem;
    color: var(--navy);
    line-height: 1.3;
    margin: 0 0 8px;
  }

  .blog-list-card p {
    color: var(--tx);
    font-size: .9rem;
    line-height: 1.6;
    margin: 0 0 12px;
  }

  .blog-list-link {
    color: var(--or);
    font-weight: 600;
    font-size: .88rem;
  }

  @media (max-width: 768px) {
    .blog-list-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

</SEOPage>
