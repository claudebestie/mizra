# ============================================================
# MIZRA BLOG AUTOMATION — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# Ne JAMAIS committer .env dans Git !
# ============================================================

# Anthropic (claude.ai/settings/api-keys)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (supabase.com → Settings → API)
SUPABASE_URL=https://XXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # Service Role key (pas l'anon key !)

# GitHub Personal Access Token
# → github.com/settings/tokens → New token (classic)
# → Permissions: repo (full), workflow
GH_PAT_TOKEN=ghp_...
GITHUB_OWNER=margauxadda      # Ton username GitHub
GITHUB_REPO=getmizra          # Nom du repo

# Netlify Build Hook
# → app.netlify.com → ton site → Site Settings → Build & Deploy → Build hooks
# → Crée un hook "Blog Automation" et copie l'URL
NETLIFY_BUILD_HOOK=https://api.netlify.com/build_hooks/XXXXXX

# WATI WhatsApp API (wati.io → Settings → API Keys)
WATI_API_URL=https://live-mt-server.wati.io/10107237
WATI_API_KEY=Bearer eyJ...   # Token complet depuis le dashboard

# Resend (transactional emails — resend.com/api-keys)
RESEND_API_KEY=re_...

# PayPlus Payment (restapi.payplus.co.il)
PAYPLUS_API_KEY=ba8d8ac1-...
PAYPLUS_SECRET_KEY=...          # Secret key from PayPlus dashboard
PAYPLUS_TERMINAL_ID=7141466010
PAYPLUS_WEBHOOK_SECRET=8dcb0c90-...

# Optionnel
ARTICLES_PER_RUN=5
WATI_DAILY_LIMIT=50          # Max messages WhatsApp par jour
WATI_SEND_HOUR_START=9       # Début envoi (heure Israel)
WATI_SEND_HOUR_END=20        # Fin envoi (heure Israel)
