---
import { getCollection } from 'astro:content';
import SEOPage from '../../layouts/SEOPage.astro';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const site = 'https://getmizra.com';
const canonical = `${site}/blog/`;
const title = 'Blog | Mizra';
const description = 'Tips, guides and news for building a professional website. The Mizra blog.';

const langColors: Record<string, string> = {
  en: '#059669',
  he: '#d97706',
};

const langLabels: Record<string, string> = {
  en: 'EN',
  he: 'HE',
};

const breadcrumbLD = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${site}/` },
    { "@type": "ListItem", "position": 2, "name": "Blog" },
  ],
};
---

<SEOPage title={title} description={description} canonical={canonical} jsonLd={[breadcrumbLD]}>

<div class="cx">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <div class="en"><a href="/">Home</a><span>/</span><span>Blog</span></div>
    <div class="he"><a href="/">דף הבית</a><span>/</span><span>בלוג</span></div>
  </nav>
</div>

<section class="page-hero">
  <div class="cx">
    <p class="sl">Blog</p>
    <div class="en">
      <h1>Articles & <i>guides</i></h1>
      <p>Practical tips to create, optimize and grow your professional website.</p>
    </div>
    <div class="he">
      <h1><i>מאמרים</i> ומדריכים</h1>
      <p>טיפים מעשיים ליצירה, אופטימיזציה וצמיחה של האתר המקצועי שלכם.</p>
    </div>
  </div>
</section>

<section class="sec">
  <div class="cx">
    <!-- Language filter tabs -->
    <div class="blog-tabs">
      <button class="blog-tab active" data-filter="all"><span class="en">All</span><span class="he">הכל</span></button>
      <button class="blog-tab" data-filter="en">English</button>
      <button class="blog-tab" data-filter="he">עברית</button>
    </div>

    {allPosts.length === 0 ? (
      <div class="en"><p style="text-align:center;color:var(--txl);padding:48px 0">No articles yet. Come back soon!</p></div>
      <div class="he"><p style="text-align:center;color:var(--txl);padding:48px 0">אין מאמרים עדיין. חזרו בקרוב!</p></div>
    ) : (
      <div class="blog-list-grid">
        {allPosts.map((post) => (
          <a href={`/blog/${post.id}/`} class="blog-list-card rv" data-lang={post.data.lang}>
            <div class="blog-list-body">
              <div class="blog-list-meta">
                <span
                  class="blog-list-lang"
                  style={`background:${langColors[post.data.lang] || '#6b7280'}`}
                >
                  {langLabels[post.data.lang] || post.data.lang.toUpperCase()}
                </span>
                <time datetime={post.data.date}>
                  {new Date(post.data.date).toLocaleDateString(post.data.lang === 'he' ? 'he-IL' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                {post.data.readingTime && <span>{post.data.readingTime}</span>}
              </div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="en"><span class="blog-list-link">Read article &rarr;</span></div>
              <div class="he"><span class="blog-list-link">&larr; קראו את המאמר</span></div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .blog-list-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 20px;
  }

  .blog-list-card {
    display: block;
    background: var(--white);
    border: 1px solid var(--bd);
    border-radius: 12px;
    text-decoration: none;
    transition: transform .3s, box-shadow .3s;
    overflow: hidden;
  }

  .blog-list-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,.06);
  }

  .blog-list-body {
    padding: 24px;
  }

  .blog-list-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: .82rem;
    color: var(--txl);
    margin-bottom: 12px;
  }

  .blog-list-lang {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: 1px;
    color: #fff;
  }

  .blog-list-card h2 {
    font-family: var(--sf);
    font-size: 1.15rem;
    color: var(--navy);
    line-height: 1.3;
    margin: 0 0 8px;
  }

  .blog-list-card p {
    color: var(--tx);
    font-size: .9rem;
    line-height: 1.6;
    margin: 0 0 12px;
  }

  .blog-list-link {
    color: var(--or);
    font-weight: 600;
    font-size: .88rem;
  }

  .blog-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
    justify-content: center;
  }

  .blog-tab {
    padding: 8px 20px;
    border: 1px solid var(--bd);
    border-radius: 100px;
    background: var(--white);
    color: var(--tx);
    font-size: .88rem;
    font-weight: 500;
    cursor: pointer;
    transition: all .2s;
  }

  .blog-tab:hover {
    border-color: var(--or);
    color: var(--or);
  }

  .blog-tab.active {
    background: var(--navy);
    color: #fff;
    border-color: var(--navy);
  }

  .blog-list-card.hidden {
    display: none;
  }

  @media (max-width: 768px) {
    .blog-list-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll('.blog-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.blog-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const filter = tab.dataset.filter;
      document.querySelectorAll('.blog-list-card').forEach(card => {
        const el = card as HTMLElement;
        if (filter === 'all' || el.dataset.lang === filter) {
          el.classList.remove('hidden');
        } else {
          el.classList.add('hidden');
        }
      });
    });
  });
</script>

</SEOPage>
