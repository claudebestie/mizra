---
import { getCollection } from 'astro:content';
import SEOPage from '../../layouts/SEOPage.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const site = 'https://getmizra.com';
const canonical = `${site}/blog/`;
const title = 'Blog | Mizra';
const description = 'Tips, guides and news for building a professional website. The Mizra blog.';

const langColors: Record<string, string> = {
  fr: '#2563eb',
  en: '#059669',
  he: '#d97706',
};

const langLabels: Record<string, string> = {
  fr: 'FR',
  en: 'EN',
  he: 'HE',
};

const breadcrumbLD = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${site}/` },
    { "@type": "ListItem", "position": 2, "name": "Blog" },
  ],
};
---

<SEOPage title={title} description={description} canonical={canonical} jsonLd={[breadcrumbLD]}>

<div class="cx">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <div class="en"><a href="/">Home</a><span>/</span><span>Blog</span></div>
    <div class="he"><a href="/">&#1512;&#1488;&#1513;&#1497;</a><span>/</span><span>&#1489;&#1500;&#1493;&#1490;</span></div>
  </nav>
</div>

<section class="page-hero">
  <div class="cx">
    <p class="sl">Blog</p>
    <h1 style="font-family:var(--sf);font-size:clamp(2rem,4.5vw,3.2rem);color:var(--navy);margin:16px 0;line-height:1.15">
      <span class="en">Articles & <i style="color:var(--or)">guides</i></span>
      <span class="he">&#1502;&#1488;&#1502;&#1512;&#1497;&#1501; &#1493;<i style="color:var(--or)">&#1502;&#1491;&#1512;&#1497;&#1499;&#1497;&#1501;</i></span>
    </h1>
    <p style="color:var(--tx);font-size:1.05rem;max-width:640px;margin:0 auto;line-height:1.7">
      <span class="en">Practical tips for creating, optimizing and growing your professional website.</span>
      <span class="he">&#1496;&#1497;&#1508;&#1497;&#1501; &#1502;&#1506;&#1513;&#1497;&#1497;&#1501; &#1500;&#1497;&#1510;&#1497;&#1512;&#1492;, &#1488;&#1493;&#1508;&#1496;&#1497;&#1502;&#1497;&#1494;&#1510;&#1497;&#1492; &#1493;&#1510;&#1502;&#1497;&#1495;&#1514; &#1492;&#1488;&#1514;&#1512; &#1492;&#1502;&#1511;&#1510;&#1493;&#1506;&#1497; &#1513;&#1500;&#1499;&#1501;.</span>
    </p>
  </div>
</section>

<section class="sec">
  <div class="cx">
    {posts.length === 0 ? (
      <p style="text-align:center;color:var(--txl);padding:48px 0">
        <span class="en">No articles yet. Check back soon!</span>
        <span class="he">&#1488;&#1497;&#1503; &#1502;&#1488;&#1502;&#1512;&#1497;&#1501; &#1506;&#1491;&#1497;&#1497;&#1503;. &#1495;&#1494;&#1512;&#1493; &#1489;&#1511;&#1512;&#1493;&#1489;!</span>
      </p>
    ) : (
      <div class="blog-list-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="blog-list-card rv" data-lang={post.data.lang}>
            <div class="blog-list-body">
              <div class="blog-list-meta">
                <span
                  class="blog-list-lang"
                  style={`background:${langColors[post.data.lang] || '#6b7280'}`}
                >
                  {langLabels[post.data.lang] || post.data.lang.toUpperCase()}
                </span>
                <time datetime={post.data.date}>
                  {new Date(post.data.date).toLocaleDateString(
                    post.data.lang === 'he' ? 'he-IL' : 'en-US',
                    { year: 'numeric', month: 'short', day: 'numeric' }
                  )}
                </time>
                {post.data.readingTime && <span>{post.data.readingTime}</span>}
              </div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <span class="blog-list-link">
                {post.data.lang === 'he' ? '\u05E7\u05E8\u05D0\u05D5 \u05E2\u05D5\u05D3 \u2190' : 'Read more \u2192'}
              </span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<script is:inline>
// Filter blog cards by current language
function filterBlogByLang() {
  const isHe = document.body.classList.contains('lh');
  const activeLang = isHe ? 'he' : 'en';
  document.querySelectorAll('.blog-list-card[data-lang]').forEach(function(card) {
    var cardLang = card.getAttribute('data-lang');
    // Show cards matching active language, hide others (fr articles always hidden unless lang is fr)
    card.style.display = (cardLang === activeLang) ? '' : 'none';
  });
}

// Run on load
document.addEventListener('DOMContentLoaded', function() {
  filterBlogByLang();

  // Re-filter when language changes — override setL
  var origSetL = window.setL;
  window.setL = function(l) {
    if (origSetL) origSetL(l);
    setTimeout(filterBlogByLang, 50);
  };
});
</script>

<style>
  .blog-list-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 20px;
  }

  .blog-list-card {
    display: block;
    background: var(--white);
    border: 1px solid var(--bd);
    border-radius: 12px;
    text-decoration: none;
    transition: transform .3s, box-shadow .3s;
    overflow: hidden;
  }

  .blog-list-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,.06);
  }

  .blog-list-body {
    padding: 24px;
  }

  .blog-list-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: .82rem;
    color: var(--txl);
    margin-bottom: 12px;
  }

  .blog-list-lang {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: 1px;
    color: #fff;
  }

  .blog-list-card h2 {
    font-family: var(--sf);
    font-size: 1.15rem;
    color: var(--navy);
    line-height: 1.3;
    margin: 0 0 8px;
  }

  .blog-list-card p {
    color: var(--tx);
    font-size: .9rem;
    line-height: 1.6;
    margin: 0 0 12px;
  }

  .blog-list-link {
    color: var(--or);
    font-weight: 600;
    font-size: .88rem;
  }

  @media (max-width: 768px) {
    .blog-list-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

</SEOPage>
