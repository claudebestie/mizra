---
import { getCollection, render } from 'astro:content';
import SEOPage from '../../layouts/SEOPage.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date, author, tags, lang, readingTime } = post.data;

const site = 'https://getmizra.com';
const canonical = `${site}/blog/${post.id}/`;

const langLabel: Record<string, string> = { fr: 'FR', en: 'EN', he: 'HE' };

const articleLD = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date,
  "author": {
    "@type": "Person",
    "name": author,
  },
  "publisher": {
    "@type": "Organization",
    "name": "Mizra",
    "url": site,
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonical,
  },
};

const breadcrumbLD = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${site}/` },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${site}/blog/` },
    { "@type": "ListItem", "position": 3, "name": title },
  ],
};
---

<SEOPage title={`${title} | Mizra Blog`} description={description} canonical={canonical} jsonLd={[articleLD, breadcrumbLD]}>

<div class="cx">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    {lang === 'he' ? (
      <Fragment><a href="/">&#1512;&#1488;&#1513;&#1497;</a><span>/</span><a href="/blog/">&#1489;&#1500;&#1493;&#1490;</a><span>/</span><span>{title}</span></Fragment>
    ) : (
      <Fragment><a href="/">Home</a><span>/</span><a href="/blog/">Blog</a><span>/</span><span>{title}</span></Fragment>
    )}
  </nav>
</div>

<article class="blog-article" dir={lang === 'he' ? 'rtl' : 'ltr'}>
  <div class="cx">
    <header class="article-header">
      <div class="article-meta">
        <span class="article-lang-badge">{langLabel[lang] || lang.toUpperCase()}</span>
        <time datetime={date}>{new Date(date).toLocaleDateString(lang === 'he' ? 'he-IL' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        {readingTime && <span class="article-reading-time">{readingTime}</span>}
      </div>
      <h1>{title}</h1>
      <p class="article-description">{description}</p>
      <div class="article-author">{lang === 'he' ? '\u05DE\u05D0\u05EA' : 'By'} {author}</div>
      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map((tag) => (
            <span class="article-tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="article-content">
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/blog/" class="article-back">{lang === 'he' ? '\u05D7\u05D6\u05E8\u05D4 \u05DC\u05D1\u05DC\u05D5\u05D2 \u2192' : '\u2190 Back to blog'}</a>
    </footer>
  </div>
</article>

<style>
  .blog-article { padding: 0 0 64px; }

  .article-header {
    max-width: 720px;
    margin: 0 auto;
    padding: 48px 0 32px;
    border-bottom: 1px solid var(--bd);
    margin-bottom: 32px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: .85rem;
    color: var(--txl);
    margin-bottom: 16px;
  }

  .article-lang-badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 4px;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: 1px;
    background: var(--navy);
    color: #fff;
  }

  .article-reading-time::before {
    content: '·';
    margin-right: 0;
    margin-left: 0;
  }

  .article-header h1 {
    font-family: var(--sf);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--navy);
    line-height: 1.2;
    margin: 0 0 16px;
  }

  .article-description {
    font-size: 1.1rem;
    color: var(--tx);
    line-height: 1.7;
    margin: 0 0 12px;
  }

  .article-author {
    font-size: .88rem;
    color: var(--txl);
    margin-bottom: 12px;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .article-tag {
    display: inline-block;
    padding: 4px 12px;
    background: var(--bg2);
    border-radius: 6px;
    font-size: .78rem;
    color: var(--tx);
  }

  .article-content {
    max-width: 720px;
    margin: 0 auto;
    font-size: 1.02rem;
    line-height: 1.8;
    color: var(--tx);
  }

  .article-content :global(h2) {
    font-family: var(--sf);
    font-size: 1.5rem;
    color: var(--navy);
    margin: 40px 0 16px;
  }

  .article-content :global(h3) {
    font-family: var(--sf);
    font-size: 1.2rem;
    color: var(--navy);
    margin: 32px 0 12px;
  }

  .article-content :global(p) {
    margin: 0 0 16px;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 0 0 16px;
    padding-left: 24px;
  }

  .article-content :global(li) {
    margin-bottom: 6px;
  }

  .article-content :global(blockquote) {
    border-left: 3px solid var(--or);
    padding: 12px 20px;
    margin: 24px 0;
    background: var(--bg2);
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: var(--txl);
  }

  .article-content :global(code) {
    background: var(--bg2);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: .9em;
  }

  .article-content :global(a) {
    color: var(--or);
    text-decoration: underline;
  }

  .article-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 10px;
    margin: 24px 0;
  }

  .article-footer {
    max-width: 720px;
    margin: 48px auto 0;
    padding-top: 24px;
    border-top: 1px solid var(--bd);
  }

  .article-back {
    color: var(--or);
    text-decoration: none;
    font-weight: 600;
    font-size: .92rem;
  }

  .article-back:hover {
    text-decoration: underline;
  }
</style>

</SEOPage>
